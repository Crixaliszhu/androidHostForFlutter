<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <import type="android.view.View" />

        <variable
            name="vm"
            type="com.example.hybriddemo.historyrelease.presentation.HistoryReleaseDemoViewModel" />

        <variable
            name="action"
            type="com.example.hybriddemo.historyrelease.presentation.HistoryReleaseDemoActionProxy" />
    </data>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F4F6F8">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <include
                android:id="@+id/topBar"
                layout="@layout/include_history_release_header" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_history_release_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvJobStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="6dp"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:historyReleaseStatusText="@{vm.uiState.statusText}" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@{vm.uiState.title}"
                    android:textColor="#111111"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@{vm.uiState.salary}"
                    android:textColor="#FF6B00"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@{vm.uiState.location}"
                    android:textColor="#333333"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@{vm.uiState.publishTime}"
                    android:textColor="#777777"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@{vm.uiState.workerCountText}"
                    android:textColor="#444444"
                    android:textSize="13sp" />

                <FrameLayout
                    android:id="@+id/flTopTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_history_release_top_time"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="6dp"
                    app:visibleGone="@{vm.uiState.showTopTime}">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text='@{"置顶到期：" + vm.uiState.topEndTime}'
                        android:textColor="#FF6B00"
                        android:textSize="12sp" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:onClick="@{() -> action.onCopy()}"
                        android:text="复制招工" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:showDividers="middle"
                    android:dividerPadding="6dp"
                    android:divider="@android:color/transparent">

                    <com.google.android.material.button.MaterialButton
                        style="@style/Widget.Material3.Button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:onClick="@{() -> action.onModify()}"
                        android:text="修改招工"
                        app:visibleGone="@{vm.uiState.showModify}" />

                    <com.google.android.material.button.MaterialButton
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:onClick="@{() -> action.onClose()}"
                        android:text="关闭招工"
                        app:visibleGone="@{vm.uiState.showClose}" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:showDividers="middle"
                    android:dividerPadding="6dp"
                    android:divider="@android:color/transparent">

                    <com.google.android.material.button.MaterialButton
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:onClick="@{() -> action.onFlush()}"
                        android:text="刷新招工"
                        app:visibleGone="@{vm.uiState.showFlush}" />

                    <com.google.android.material.button.MaterialButton
                        style="@style/Widget.Material3.Button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:onClick="@{() -> action.onTop()}"
                        android:text="置顶招工"
                        app:visibleGone="@{vm.uiState.showTop}" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:showDividers="middle"
                    android:dividerPadding="6dp"
                    android:divider="@android:color/transparent">

                    <com.google.android.material.button.MaterialButton
                        style="@style/Widget.Material3.Button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:onClick="@{() -> action.onModifyTop()}"
                        android:text="修改置顶"
                        app:visibleGone="@{vm.uiState.showModifyTop}" />

                    <com.google.android.material.button.MaterialButton
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:onClick="@{() -> action.onRedo()}"
                        android:text="重新发布"
                        app:visibleGone="@{vm.uiState.showRedo}" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:onClick="@{() -> action.onManageRecruit()}"
                    android:text="管理招工"
                    android:textColor="#1366EC"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:visibleGone="@{vm.uiState.showManageRecruit}" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_history_release_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="操作日志"
                    android:textColor="#111111"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@{vm.actionLog}"
                    android:textColor="#555555" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</layout>
